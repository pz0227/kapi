# Kapi Analytics Backend — example environment config.
# Copy this file to `analytics-backend/.env` and fill in ONE provider key,
# OR configure a provider in the app (Settings) / via `kapi configure`.
# NEVER commit your real .env — it is gitignored.

# ── LLM provider API keys (set the one you use) ─────────────────────────────
# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mistral
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# xAI (Grok)
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ollama (local, no key needed) — point at your local server instead
# OLLAMA_BASE_URL=http://localhost:11434

# The OpenClaw / `kapi` gateway (OpenAI Codex OAuth) needs no key here — it is
# authenticated separately with:  kapi models auth login --provider openai-codex
