# ── Kapi Analytics Backend Configuration ─────────────────────────────────────
# Copy to .env and fill in your values.

# ── Auth Mode ────────────────────────────────────────────────────────────────
# "local" = no auth (self-hosted, single user)
# "clerk" = Clerk JWT auth (SaaS, multi-tenant)
KAPI_AUTH_MODE=local

# ── Clerk (required if KAPI_AUTH_MODE=clerk) ─────────────────────────────────
# CLERK_DOMAIN=your-app.clerk.accounts.dev
# CLERK_SECRET_KEY=sk_live_...
# CLERK_PUBLISHABLE_KEY=pk_live_...

# ── Stripe Billing (required for paid plans) ─────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_STARTER_PRICE_ID=price_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_TEAM_PRICE_ID=price_...

# ── LLM Provider API Keys (at least one required) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=

# ── Application ──────────────────────────────────────────────────────────────
APP_URL=http://localhost:18789
DEBUG=false
# CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
